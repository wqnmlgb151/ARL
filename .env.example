# ARL 环境变量配置
# 复制此文件为 .env 并填写实际值
# 警告：.env 文件不应提交到版本控制！

# ===== 应用配置 =====
FLASK_DEBUG=false
FLASK_PORT=5018
FLASK_HOST=127.0.0.1

# ===== 数据库配置 =====
MONGO_URL=mongodb://127.0.0.1:27017/
MONGO_DB=ARLV2

# ===== Celery 配置 =====
CELERY_BROKER_URL=amqp://arl:arlpassword@localhost:5672/arlv2host

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== 认证配置 =====
ARL_AUTH=true
ARL_API_KEY=your-secure-api-key-here

# ===== 代理配置（可选） =====
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# ===== 第三方 API 密钥 =====
FOFA_KEY=
FOFA_URL=https://fofa.info
GITHUB_TOKEN=

# ===== 通知配置（可选） =====
DINGDING_SECRET=
DINGDING_ACCESS_TOKEN=
FEISHU_WEBHOOK=
FEISHU_SECRET=
WX_WORK_WEBHOOK=

# ===== 邮箱配置（可选） =====
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

# ===== 安全配置 =====
# 仅在开发环境设置为 true
ARL_DISABLE_SSL_VERIFY=false
HTTPS_ENABLED=false

